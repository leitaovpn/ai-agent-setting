{
  "permissions": {
    "deny": [
      "Edit(.claude/**)",
      "Write(.claude/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "filesystem": {
      "allowWrite": ["/tmp"],
      "denyWrite": [],
      "allowRead": [],
      "denyRead": []
    },
    "network": {
      "allowedDomains": [
        "*"
      ],
      "deniedDomains": [
      ],
      "allowLocalBinding": true
    }
  }
  
}
